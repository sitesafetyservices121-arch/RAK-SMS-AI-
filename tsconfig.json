{
  "compilerOptions": {
    /* Language & Environment */
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "jsx": "preserve",

    /* Type Checking */
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "incremental": true,
    "esModuleInterop": true,
    "allowJs": true,
    "resolveJsonModule": true,

    /* Module System */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* Path Aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Type Declarations */
    "typeRoots": ["./types", "./node_modules/@types"],
    "types": ["node", "next"],

    /* Plugins */
    "plugins": [{ "name": "next" }],

    /* Optional Strictness (uncomment if you want max safety) */
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
